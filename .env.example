# API Keys
# Get a Google Places API key from: https://console.cloud.google.com/google/maps-apis/
# Enable Places API, Reviews API
GOOGLE_PLACES_API_KEY=

# Alternative free APIs (optional)
# Foursquare API - https://foursquare.com/developers/
FOURSQUARE_API_KEY=

# OpenTripMap for places info (free tier) - https://opentripmap.com/
OPENTRIPMAP_API_KEY=